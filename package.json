{
  "name": "logseq-maps-plugin",
  "author": "benjypng",
  "description": "Create maps as part of your notes.",
  "license": "MIT",
  "logseq": {
    "id": "logseq-maps-plugin",
    "title": "logseq-maps-plugin",
    "icon": "./icon.svg",
    "main": "dist/index.html"
  },
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "prepare": "husky",
    "lint:precommit": "echo \"Running biome\" && bunx @biomejs/biome check --write . && echo \"Running tsc\" && tsc --noEmit"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      [
        "@semantic-release/github",
        {
          "assets": ["logseq-maps-plugin.zip"]
        }
      ]
    ]
  },
  "dependencies": {
    "@logseq/libs": "^0.2.10",
    "@react-leaflet/core": "^3.0.0",
    "axios": "^1.13.2",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.69.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-logseq": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.3"
  }
}
